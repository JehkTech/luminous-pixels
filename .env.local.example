# ─── Resend (Email) ──────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Sanity CMS ──────────────────────────────────────
# Get these from: https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── PostHog Analytics ───────────────────────────────
# Get at: https://app.posthog.com/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Site URL ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://luminouspixels.agency
